# LinkedIn Content Coach — environment variables
#
# This file documents every env var the app uses. Copy to .env.local for local
# development. On Vercel, these are set via the project's Environment Variables
# panel (or prompted automatically during the "Deploy with Vercel" flow).

# ============================================================================
# Required: Auth
# ============================================================================

# The single password for this instance. Set this once during deploy. Used:
#   1. To log in to the app from any device
#   2. As input to derive the AES key that encrypts the user's stored LLM API key
#
# Minimum 12 characters. Change this only with care: rotating AUTH_PASSWORD
# makes the existing encrypted API key undecryptable, so you'll be asked to
# re-enter your LLM API key on next login after a rotation.
AUTH_PASSWORD=

# Random 32+ character string used by Auth.js to sign session JWTs.
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ============================================================================
# Required: Database (auto-set by Vercel Postgres integration)
# ============================================================================

# Vercel Postgres (Neon) connection string. On Vercel, this is set
# automatically when you attach the Postgres integration during deploy.
# For local dev, point this at a local Postgres or a Vercel branch URL.
POSTGRES_URL=

# ============================================================================
# Optional: Defaults
# ============================================================================

# Optional default LLM API key. If set, pre-fills the setup wizard. Most users
# leave this empty and enter their key through the UI, where it's encrypted at
# rest with their AUTH_PASSWORD-derived key.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
